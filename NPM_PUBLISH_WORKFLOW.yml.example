name: npm publish

on:
  workflow_dispatch:
    inputs:
      publish:
        description: "Publish softjunk-lead-kit to npmjs when NPM_TOKEN is configured"
        required: true
        default: "false"
        type: choice
        options:
          - "false"
          - "true"

permissions:
  contents: read

jobs:
  dry-run:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "20"
          registry-url: "https://registry.npmjs.org"
      - run: npm ci --ignore-scripts
        if: hashFiles('package-lock.json') != ''
      - run: npm pack --dry-run --json
      - run: node bin/softjunk-lead-kit.js doctor --json
      - run: node bin/softjunk-lead-kit.js pay --mode custom --json

  publish:
    if: inputs.publish == 'true'
    needs: dry-run
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "20"
          registry-url: "https://registry.npmjs.org"
      - run: npm ci --ignore-scripts
        if: hashFiles('package-lock.json') != ''
      - run: npm publish --access public
        env:
          NODE_AUTH_TOKEN: ${{ secrets.NPM_TOKEN }}
