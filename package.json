{
    "name": "softjunk-lead-kit",
    "version": "0.2.2",
    "private": false,
    "description": "Dependency-free local CLI and MCP checkout tools for the SoftJunk 5 USD PayPal lead follow-up handoff.",
    "homepage": "https://paypal.me/softjunk/5USD",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/trungcodeer/softjunk-lead-kit.git"
    },
    "bugs": {
        "url": "https://github.com/trungcodeer/softjunk-lead-kit/issues"
    },
    "keywords": [
        "lead-follow-up",
        "paypal",
        "buyer-agent",
        "npm-fund",
        "softjunk"
    ],
    "funding": {
        "type": "custom",
        "url": "https://paypal.me/softjunk/5USD"
    },
    "bin": {
        "softjunk-lead-kit": "bin/softjunk-lead-kit.js",
        "softjunk-mcp-checkout": "mcp-server-softjunk.js"
    },
    "scripts": {
        "cli:smoke": "node bin/softjunk-lead-kit.js doctor --json && node bin/softjunk-lead-kit.js kit --json && node bin/softjunk-lead-kit.js pay --mode kit --json",
        "mcp:smoke": "node mcp-server-softjunk.js",
        "start": "node bin/softjunk-lead-kit.js doctor --json",
        "try:rescue": "node bin/softjunk-lead-kit.js rescue --business \"roofing contractor\" --service \"roof estimate\" --source estimate --need \"unanswered estimate\" --tone direct --next quote --json",
        "try:send": "node bin/softjunk-lead-kit.js send --business \"med spa\" --service consultation --source DM --need \"quiet inquiry\"",
        "pay:custom": "node bin/softjunk-lead-kit.js pay --mode custom --json",
        "pay:kit": "node bin/softjunk-lead-kit.js pay --mode kit --json",
        "fund": "node bin/softjunk-lead-kit.js pay --mode custom --json",
        "fund:kit": "node bin/softjunk-lead-kit.js pay --mode kit --json",
        "dev:first": "npm start",
        "agent:first": "npm start",
        "agent:preview": "npm run try:rescue",
        "agent:pay": "npm run pay:custom",
        "codespaces:first": "npm start"
    },
    "engines": {
        "node": ">=18"
    },
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "softjunk": {
        "run_this_first_url": "https://trungcodeer.github.io/softjunk-lead-kit/RUN_THIS_FIRST.md",
